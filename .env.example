POSTGRES_DB=mediconnect
POSTGRES_USER=mediconnect
POSTGRES_PASSWORD=change-me-postgres-password

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mediconnect
SPRING_DATASOURCE_USERNAME=mediconnect
SPRING_DATASOURCE_PASSWORD=change-me-postgres-password
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5

JWT_SECRET=change-me-to-a-strong-64-character-secret-value
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

SPRING_MAIL_HOST=mailhog
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=change-me@example.com
SPRING_MAIL_PASSWORD=change-me-mail-password
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=/api/v1
